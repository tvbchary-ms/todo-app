# Database
DATABASE_URL=postgresql://todo_user:todo_password@localhost:5432/todo_db

# JWT
JWT_SECRET=change-me-in-production-use-aws-ssm
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173

# AWS (for backups — leave empty for local dev)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
