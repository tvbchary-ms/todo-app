{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"todo-backend\"}[5m]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"todo-backend\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_errors_total{job=\"todo-backend\"}[5m])) / sum(rate(http_requests_total{job=\"todo-backend\"}[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_request_errors_total{job=\"todo-backend\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"todo-backend\"}[5m]))",
          "legendFormat": "5xx Rate",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"todo-backend\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"todo-backend\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"todo-backend\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "http_active_connections{job=\"todo-backend\"}",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30 },
          "unit": "decmbytes"
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"todo-backend\"} / 1024 / 1024",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"todo-backend\"} / 1024 / 1024",
          "legendFormat": "Heap Used",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"todo-backend\"} * 1000",
          "legendFormat": "Event Loop Lag",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"todo-backend\"}[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"todo-backend\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["todo", "backend", "red-metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
